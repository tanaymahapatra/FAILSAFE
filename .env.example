# ==========================================
# FAILSAFE PLATFORM - ENVIRONMENT VARIABLES
# ==========================================
# INSTRUCTIONS: Copy this file, rename it to '.env', and fill in your own values.


# --- Authentication ---
# Generate a secure, random 64-character string for this value.
#
JWT_SECRET_KEY=replace_this_with_a_secure_random_string

# --- Database ---
# If you are running the project using the provided Docker Compose setup, 
# you can leave this exact URL. Docker will automatically configure it!
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://myuser:mypassword@db:5432/failsafe_db